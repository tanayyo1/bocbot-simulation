<?xml version='1.0'?>
<robot name="bocbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="bocbot.gazebo" />

  <!-- Base footprint -->
  <link name="robot_footprint"></link>

  <!-- Ground contact anchor. Start close to ground -->
  <joint name="robot_footprint_joint" type="fixed">
    <origin xyz="0 0 0.15" rpy="0 0 0" />
    <parent link="robot_footprint"/>
    <child link="base_link" />
  </joint>

  <!-- Main Chassis -->
  <link name='base_link'>
    <inertial>
      <!-- Reduced mass significantly to stop violent collision resolving -->
      <mass value="3.0"/>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05" />
    </inertial>
    <collision name='collision'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <!-- Made collision box slightly smaller than visual to prevent snagging -->
      <geometry>
        <box size="0.28 0.18 0.10"/>
      </geometry>
    </collision>
    <visual name='chassis_visual'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <geometry>
        <box size="0.30 0.20 0.12"/>
      </geometry>
    </visual>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- Camera -->
  <link name="camera">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
    <visual name="camera_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.05 0.03"/>
      </geometry>
    </visual>
    <!-- Removed camera collision entirely to stop internal intersection jitter -->
  </link>

  <!-- Hokuyo -->
  <link name="hokuyo">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
    <visual name="hokuyo_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </visual>
    <!-- Removed hokuyo collision entirely to stop internal intersection jitter -->
  </link>

  <joint type="fixed" name="camera_joint">
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <child link="camera"/>
    <parent link="base_link"/>
  </joint>

  <joint type="fixed" name="hokuyo_joint">
    <origin xyz="0.1 0 0.06" rpy="0 0 0"/>
    <child link="hokuyo"/>
    <parent link="base_link"/>
  </joint>

  <gazebo reference="camera"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="hokuyo"><material>Gazebo/Black</material></gazebo>


  <!-- =============================== -->
  <!-- LEFT SIDE ROCKER-BOGIE ASSEMBLY -->
  <!-- =============================== -->

  <!-- Left Main Rocker Arm -->
  <link name="left_rocker_arm">
    <inertial>
      <!-- Ensure arm mass is much lower than base -->
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.34 0.04 0.04"/></geometry>
    </visual>
    <visual>
      <origin xyz="0.2 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.10"/></geometry>
    </visual>
    <visual>
      <origin xyz="-0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0 -0.025" rpy="0 0 0"/>
      <!-- Thinned the collision box -->
      <geometry><box size="0.30 0.02 0.05"/></geometry>
    </collision>
  </link>
  <gazebo reference="left_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- To fix "jumping", we switch this from revolute to continuous for Gazebo solver stability -->
  <joint name="left_differential_axle" type="continuous">
    <origin xyz="0.0 0.13 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <!-- Provide reasonable friction to prevent floppy legs -->
    <dynamics damping="5.0" friction="5.0"/>
  </joint>

  <!-- Left Front Wheel -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <!-- Using exactly calculated cylinder inertia: 1/12m(3r^2+h^2), 1/2mr^2 -->
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Grey</material>
    <!-- Physics engine traction tags -->
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.2 0.06 -0.1" rpy="0 0 0"/>
    <parent link="left_rocker_arm"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Left Bogie Link -->
  <link name="left_bogie_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
    </visual>
    <visual>
      <origin xyz="0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <visual>
      <origin xyz="-0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.20 0.02 0.05"/></geometry>
    </collision>
  </link>
  <gazebo reference="left_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Also changed to continuous for stability -->
  <joint name="left_bogie_pivot" type="continuous">
    <origin xyz="-0.1 0.0 -0.05" rpy="0 0 0"/>
    <parent link="left_rocker_arm"/>
    <child link="left_bogie_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="500" velocity="10"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <!-- Left Middle Wheel -->
  <link name="mid_left_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="mid_left_wheel">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="mid_left_wheel_joint" type="continuous">
    <origin xyz="0.1 0.06 -0.05" rpy="0 0 0"/>
    <parent link="left_bogie_link"/>
    <child link="mid_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Left Rear Wheel -->
  <link name="back_left_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_left_wheel">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="back_left_wheel_joint" type="continuous">
    <origin xyz="-0.1 0.06 -0.05" rpy="0 0 0"/>
    <parent link="left_bogie_link"/>
    <child link="back_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>


  <!-- ================================ -->
  <!-- RIGHT SIDE ROCKER-BOGIE ASSEMBLY -->
  <!-- ================================ -->

  <!-- Right Main Rocker Arm -->
  <link name="right_rocker_arm">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.34 0.04 0.04"/></geometry>
    </visual>
    <visual>
      <origin xyz="0.2 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.10"/></geometry>
    </visual>
    <visual>
      <origin xyz="-0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.30 0.02 0.05"/></geometry>
    </collision>
  </link>
  <gazebo reference="right_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_differential_axle" type="continuous">
    <origin xyz="0.0 -0.13 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <dynamics damping="5.0" friction="5.0"/>
  </joint>

  <!-- Right Front Wheel -->
  <link name="front_right_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_right_wheel">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.2 -0.06 -0.1" rpy="0 0 0"/>
    <parent link="right_rocker_arm"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Right Bogie Link -->
  <link name="right_bogie_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
    </visual>
    <visual>
      <origin xyz="0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <visual>
      <origin xyz="-0.1 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.05"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.20 0.02 0.05"/></geometry>
    </collision>
  </link>
  <gazebo reference="right_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_bogie_pivot" type="continuous">
    <origin xyz="-0.1 0.0 -0.05" rpy="0 0 0"/>
    <parent link="right_rocker_arm"/>
    <child link="right_bogie_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="500" velocity="10"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <!-- Right Middle Wheel -->
  <link name="mid_right_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="mid_right_wheel">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="mid_right_wheel_joint" type="continuous">
    <origin xyz="0.1 -0.06 -0.05" rpy="0 0 0"/>
    <parent link="right_bogie_link"/>
    <child link="mid_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Right Rear Wheel -->
  <link name="back_right_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry><cylinder length="0.05" radius="0.075"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <joint name="back_right_wheel_joint" type="continuous">
    <origin xyz="-0.1 -0.06 -0.05" rpy="0 0 0"/>
    <parent link="right_bogie_link"/>
    <child link="back_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

</robot>