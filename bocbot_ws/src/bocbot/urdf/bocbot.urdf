    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <joint name="front_left_wheel_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0.2 0.06 -0.1"/>
    <parent link="left_rocker_arm"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <!-- Left Bogie Link -->
  <link name="left_bogie_link">
    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
