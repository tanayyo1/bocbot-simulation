<!-- =================================================================================== -->
<robot name="bocbot">
  <!-- Hexapedal Rocker-Bogie Plugin Configuration -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="skid_steer_drive_controller">
      <ros>
        <namespace>/bocbot</namespace>
        <remapping>~/cmd_vel:=cmd_vel</remapping>
        <remapping>~/odom:=odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <!-- We have 3 pairs of wheels now! -->
      <num_wheel_pairs>3</num_wheel_pairs>
      <odometry_frame>odom</odometry_frame>
      <!-- Left Wheels -->
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>mid_left_wheel_joint</left_joint>
      <left_joint>back_left_wheel_joint</left_joint>
      <!-- Right Wheels -->
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>mid_right_wheel_joint</right_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <!-- Distances adjusted to match new geometry (y offsets) -->
      <wheel_separation>0.38</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <robot_base_frame>robot_footprint</robot_base_frame>
      <max_wheel_torque>50</max_wheel_torque>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_source>world</odometry_source>
    </plugin>
  </gazebo>
  <!-- camera -->
  <gazebo reference="camera">
    <sensor name="camera_sensor" type="camera">
      <update_rate>30.0</update_rate>
      <always_on>1</always_on>
      <camera name="camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>800</width>
          <height>800</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <distortion>
          <k1>0.0</k1>
          <k2>0.0</k2>
          <k3>0.0</k3>
          <p1>0.0</p1>
          <p2>0.0</p2>
          <center>0.5 0.5</center>
        </distortion>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <ros>
          <namespace>/bocbot</namespace>
          <argument>camera/image_raw:=/bocbot/camera/image</argument>
          <argument>camera/camera_info:=/bocbot/camera/image/camera_info</argument>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera</frame_name>
        <hack_baseline>0.07</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>
  <!-- hokuyo -->
  <gazebo reference="hokuyo">
    <sensor name="head_hokuyo_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-1.570796</min_angle>
            <max_angle>1.570796</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="gazebo_ros_head_hokuyo_controller">
        <ros>
          <namespace>/bocbot</namespace>
          <argument>~/out:=scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>
  <!-- Base footprint -->
  <link name="robot_footprint"/>
  <!-- Ground contact anchor. Start close to ground -->
  <joint name="robot_footprint_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.15"/>
    <parent link="robot_footprint"/>
    <child link="base_link"/>
  </joint>
  <!-- Main Chassis -->
  <link name="base_link">
    <inertial>
      <!-- Reduced mass significantly to stop violent collision resolving -->
      <mass value="3.0"/>
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <collision name="collision">
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <!-- Made collision box slightly smaller than visual to prevent snagging -->
      <geometry>
        <box size="0.28 0.18 0.10"/>
      </geometry>
    </collision>
    <visual name="chassis_visual">
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.30 0.20 0.12"/>
      </geometry>
    </visual>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>
  <!-- Camera -->
  <link name="camera">
    <inertial>
      <mass value="0.01"/>
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual name="camera_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.05 0.03"/>
      </geometry>
    </visual>
    <!-- Removed camera collision entirely to stop internal intersection jitter -->
  </link>
  <!-- Hokuyo -->
  <link name="hokuyo">
    <inertial>
      <mass value="0.01"/>
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual name="hokuyo_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.03"/>
      </geometry>
    </visual>
    <!-- Removed hokuyo collision entirely to stop internal intersection jitter -->
  </link>
  <joint name="camera_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.15 0 0"/>
    <child link="camera"/>
    <parent link="base_link"/>
  </joint>
  <joint name="hokuyo_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.1 0 0.06"/>
    <child link="hokuyo"/>
    <parent link="base_link"/>
  </joint>
  <gazebo reference="camera">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="hokuyo">
    <material>Gazebo/Black</material>
  </gazebo>
  <!-- =============================== -->
  <!-- LEFT SIDE ROCKER-BOGIE ASSEMBLY -->
  <!-- =============================== -->
  <!-- Left Main Rocker Arm -->
  <link name="left_rocker_arm">
    <inertial>
      <!-- Ensure arm mass is much lower than base -->
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.05 0 0"/>
      <geometry>
        <box size="0.34 0.04 0.04"/>
      </geometry>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0.2 0 -0.05"/>
      <geometry>
        <box size="0.04 0.04 0.10"/>
      </geometry>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="-0.1 0 -0.025"/>
      <geometry>
        <box size="0.04 0.04 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.05 0 -0.025"/>
      <!-- Thinned the collision box -->
      <geometry>
        <box size="0.30 0.02 0.05"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="left_rocker_arm">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <!-- To fix "jumping", we switch this from revolute to continuous for Gazebo solver stability -->
  <joint name="left_differential_axle" type="continuous">
    <origin rpy="0 0 0" xyz="0.0 0.13 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <!-- Provide reasonable friction to prevent floppy legs -->
    <dynamics damping="5.0" friction="5.0"/>
  </joint>
  <!-- Left Front Wheel -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <!-- Using exactly calculated cylinder inertia: 1/12m(3r^2+h^2), 1/2mr^2 -->
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022"/>
    </inertial>
    <visual>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="front_left_wheel">
